8:                    vehicle_year, description, media):
9:     request = {
10:         "user_id": ObjectId(user_id), # Tied to the requesting user
11:         "workshop_id": None, # Unclaimed initially
12:         "assigned_mechanic_id": None, # Unassigned initially
13:         "vehicle_type": vehicle_type,
...
18:         "media": media,
19:         "status": "Pending", # Starts as Pending
20:         "created_at": datetime.utcnow(),
21:     }
22:     result = mongo.db.service_requests.insert_one(request)
23:     return result.inserted_id
```

## 10. [extensions.py](file:///d:/project/new%20project/road_rescue/extensions.py) and [utils/notifications.py](file:///d:/project/new%20project/road_rescue/utils/notifications.py) - Core Utilities

These files contain simple but essential helper functions used throughout the rest of the application.

### [extensions.py](file:///d:/project/new%20project/road_rescue/extensions.py)
This file is used to prevent "circular imports" in Flask. By instantiating `PyMongo` here, BOTH [app.py](file:///d:/project/new%20project/road_rescue/app.py) (which configures the app) and [routes.py](file:///d:/project/new%20project/road_rescue/blueprints/user/routes.py) (which use the database) can import `mongo` safely without accidentally importing each other.

```python
1: from flask_pymongo import PyMongo
2: 
3: mongo = PyMongo()
```

### [utils/notifications.py](file:///d:/project/new%20project/road_rescue/utils/notifications.py)
This file simulates sending out Emails and SMS messages. In a production environment, this is where you would integrate APIs like Twilio (for SMS) or SendGrid/Amazon SES (for emails). Currently, it mocks the functionality by printing the messages to the server's console terminal.

```python
1: import logging
2: 
# Sets up a basic Python logger to output to the console
3: logging.basicConfig(level=logging.INFO)
4: logger = logging.getLogger("Notifications")
5: 
6: def send_email_notification(to_email, subject, body):
7:     """Simulate sending an email."""
8:     msg = f"\n=== EMAIL SIMULATION ===\nTo: {to_email}\nSubject: {subject}\nBody:\n{body}\n========================\n"
9:     logger.info(f"[EMAIL MOCK] {to_email} : {subject}")
10:     print(msg) # Output the mock email text to the terminal
11:     return True
12: 
13: def send_sms_alert(to_phone, message):
14:     """Simulate sending an SMS alert."""
15:     msg = f"\n=== SMS SIMULATION ===\nTo: {to_phone}\nMessage: {message}\n======================\n"
16:     logger.info(f"[SMS MOCK] {to_phone} : {message}")
17:     print(msg) # Output the mock SMS text to the terminal
18:     return True
```


