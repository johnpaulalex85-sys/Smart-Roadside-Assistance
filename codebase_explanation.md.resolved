# Road Rescue Application - Codebase Explanation

This document provides a detailed line-by-line explanation of the core application files and their working flow.

## 1. [app.py](file:///d:/project/new%20project/road_rescue/app.py) - Application Factory and Entry Point

This file serves as the core entry point of the application. It uses the Flask application factory pattern.

```python
# Imports necessary standard library modules, Flask class, configuration class, database extension and password hashing utility.
1: import os
2: from flask import Flask
3: from config import Config
4: from extensions import mongo
5: from werkzeug.security import generate_password_hash

# The application factory function which creates and configures the Flask app instance.
8: def create_app():
# Instantiates the Flask app object.
9:     app = Flask(__name__)
# Loads configuration variables from the Config class in config.py.
10:     app.config.from_object(Config)

# Ensures that the directory specified in the UPLOAD_FOLDER configuration exists, creating it if it doesn't.
12:     # Ensure upload folder exists
13:     os.makedirs(app.config["UPLOAD_FOLDER"], exist_ok=True)

# Initializes the PyMongo extension with the created Flask app instance, enabling database connectivity.
15:     mongo.init_app(app)

# The following operations require the app context to be active to interact with the database.
17:     # Create 2dsphere index for workshops + seed default admin
18:     with app.app_context():
19:         try:
# Attempts to create a geospatial index "2dsphere" on the "location" field of the "workshops" collection.
# This enables proximity searches (like finding nearby workshops based on GPS coordinates).
20:             mongo.db.workshops.create_index([("location", "2dsphere")])
21:         except Exception:
# Catches and silently ignores any exception that occurs during index creation (e.g. if the index already exists).
22:             pass

# Checks if an admin account with the email "admin@smartroadsideassistance.com" already exists in the "admins" collection.
24:         # Seed default admin account
25:         if not mongo.db.admins.find_one({"email": "admin@smartroadsideassistance.com"}):
# If it doesn't exist, it inserts a default admin document with a hashed password, establishing an initial administrative login.
26:             mongo.db.admins.insert_one({
27:                 "email": "admin@smartroadsideassistance.com",
28:                 "name": "Super Admin",
29:                 "password": generate_password_hash("Admin@1234"),
30:                 "role": "admin",
31:             })

# Imports the defined blueprints (modules) for different parts of the application (authentication, user dashboard, workshop management, etc.)
33:     # Register blueprints
34:     from blueprints.auth import auth_bp
35:     from blueprints.user import user_bp
36:     from blueprints.workshop import workshop_bp
37:     from blueprints.mechanic import mechanic_bp
38:     from blueprints.admin import admin_bp
39:     from blueprints.payment.routes import payment_bp

# Registers each imported blueprint with the Flask application instance, mounting them under specific URL prefixes.
# For example, all routes defined in auth_bp will be prefixed with /auth (e.g., /auth/login).
41:     app.register_blueprint(auth_bp, url_prefix="/auth")
42:     app.register_blueprint(user_bp, url_prefix="/user")
43:     app.register_blueprint(workshop_bp, url_prefix="/workshop")
44:     app.register_blueprint(mechanic_bp, url_prefix="/mechanic")
45:     app.register_blueprint(admin_bp, url_prefix="/admin")
46:     app.register_blueprint(payment_bp)  # Registers without prefix

# Imports redirect and url_for for route redirection.
48:     # Root redirect
49:     from flask import redirect, url_for

# Defines the root route ("/") of the application.
51:     @app.route("/")
52:     def index():
# When a user visits the root URL "/"), they are immediately redirected to the "login" endpoint defined in the "auth" blueprint.
53:         return redirect(url_for("auth.login"))

# Returns the fully configured Flask application instance.
55:     return app

# The standard Python block that executes only if the script is run directly (not imported as a module).
58: if __name__ == "__main__":
# Calls the factory function to create the app.
59:     app = create_app()
# Starts the Flask development server in debug mode listening on port 5001.
60:     app.run(debug=True, port=5001)
```

## 2. [config.py](file:///d:/project/new%20project/road_rescue/config.py) - Configuration Settings

This file holds configuration parameters for the Flask application.

```python
# Imports standard os library for grabbing environment variables and timedelta for specifying durations.
1: import os
2: from datetime import timedelta

# Defines a Config class which holds constants. Flask loads configurations directly from class attributes.
4: class Config:
# Sets the secret key used for securely signing the session cookie. Retrieves from environment or defaults to the given string.
5:     SECRET_KEY = os.environ.get("SECRET_KEY", "road_rescue_super_secret_key_2024")
# Sets the MongoDB connection string. Uses environment variable or defaults to a hardcoded MongoDB Atlas credential.
6:     MONGO_URI = os.environ.get("MONGO_URI", "mongodb+srv://mechanicaluser:kolonia%40123@cluster0.7lpf3re.mongodb.net/road_rescue?appName=Cluster0")
# Constructs the absolute path to the folder where user uploads (images, etc) are saved natively on the system.
7:     UPLOAD_FOLDER = os.path.join(os.path.dirname(__file__), "static", "uploads")
# Limits the maximum allowed payload to 50 MB, preventing users from uploading excessively large files that could affect server stability.
8:     MAX_CONTENT_LENGTH = 50 * 1024 * 1024  # 50 MB
# Defines a set of file extensions that the application accepts for file uploads.
9:     ALLOWED_EXTENSIONS = {"jpg", "jpeg", "png", "mp4"}
# The API key required for rendering and using Google Maps services on the frontend.
10:     GOOGLE_MAPS_API_KEY = os.environ.get("GOOGLE_MAPS_API_KEY", "YOUR_GOOGLE_MAPS_API_KEY")
# Specifies that persistent sessions should last for 30 days before users are logged out and need to re-authenticate.
11:     PERMANENT_SESSION_LIFETIME = timedelta(days=30)
```

## 3. [blueprints/auth/routes.py](file:///d:/project/new%20project/road_rescue/blueprints/auth/routes.py) - Authentication System

This file manages user authentication, including login, logout, and registration logic for different roles (user, workshop, mechanic, admin).

```python
# Standard library imports
1: import os
2: import re
# Flask core utilities for request handling, template rendering, sessions and flashing messages
3: from flask import render_template, request, redirect, url_for, session, flash
# Werkzeug utilities for securely hashing passwords before storing them
4: from werkzeug.security import generate_password_hash, check_password_hash
# Imports the blueprint object itself where these routes are registered
5: from blueprints.auth import auth_bp
# Database extension for MongoDB interaction
6: from extensions import mongo
# Date and time utilities for lockouts and tracking
7: from datetime import datetime, timedelta
# Custom utility for sending emails, likely used when a new account requires approval or verification
8: from utils.notifications import send_email_notification

# Helper function to enforce strong password policies
11: def is_valid_password(pwd: str) -> bool:
12:     if not isinstance(pwd, str): return False
# Checks for minimum length of 8, at least one uppercase letter, and at least one digit
13:     return len(pwd) >= 8 and bool(re.search(r"[A-Z]", pwd)) and bool(re.search(r"\d", pwd))

# Core helper function for processing login attempts across multiple roles
16: def _allowed_role_login(collection, email, password, role_key, id_key):
# Looks up the user document by email in the dynamically specified collection (e.g. "users", "admins")
17:     record = mongo.db[collection].find_one({"email": email})
18:     if not record:
19:         return None # User not found
20: 
21:     # Check if account is locked due to too many failed login attempts
22:     if record.get("locked_until") and record["locked_until"] > datetime.utcnow():
23:         return "LOCKED"
24: 
25:     # Check if the workshop account is still waiting for administrative approval
26:     if role_key == "workshop" and record.get("status") == "pending":
27:         return "PENDING_APPROVAL"
28:         
29:     # Check if the account has been explicitly blocked by an admin
30:     if record.get("is_blocked"):
31:         return "BLOCKED"
32: 
# Compares the provided plaintext password against the hash stored in the database
33:     if check_password_hash(record["password"], password):
34:         # If login is successful, reset the failed_attempts counter and unlock the account
35:         if record.get("failed_attempts", 0) > 0:
36:             mongo.db[collection].update_one(
37:                 {"_id": record["_id"]},
38:                 {"$set": {"failed_attempts": 0, "locked_until": None}}
39:             )
40: 
# Clears old session data to prevent session fixation attacks
41:         session.clear()
42:         session.permanent = True # Enables the long-lived session defined in config.py
# Sets the user's identifying info into the encrypted Flask session cookie
43:         session[id_key] = str(record["_id"])
44:         session["role"] = role_key
45:         session["name"] = record.get("name", record.get("email", ""))
46:         return record # Returns the user record indicating success
47:     else:
48:         # Increment failed attempts counter if password is wrong
49:         attempts = record.get("failed_attempts", 0) + 1
50:         updates = {"failed_attempts": attempts}
# If there are 5 or more failed attempts, lock the account for 15 minutes
51:         if attempts >= 5:
52:             updates["locked_until"] = datetime.utcnow() + timedelta(minutes=15)
53:         
54:         mongo.db[collection].update_one({"_id": record["_id"]}, {"$set": updates})
55:         return "INVALID"

# Defines the actual route for the login page
58: # ─── Login ───────────────────────────────────────────────────────────────────
59: @auth_bp.route("/login", methods=["GET", "POST"])
60: def login():
61:     if request.method == "POST":
# Retrieves form data sent by the browser
62:         role = request.form.get("role")
63:         email = request.form.get("email", "").strip().lower() # Normalizes email
64:         password = request.form.get("password", "")
65: 
# Maps user roles to their respective MongoDB collections, session ID keys, and destination pages after login
66:         collection_map = {
67:             "user": ("users", "user_id", "user.dashboard"),
68:             "workshop": ("workshops", "workshop_id", "workshop.dashboard"),
69:             "mechanic": ("mechanics", "mechanic_id", "mechanic.dashboard"),
70:             "admin": ("admins", "admin_id", "admin.dashboard")
71:         }
72: 
73:         if role in collection_map:
# Extracts the mapped configuration for the selected role
74:             coll, id_key, endpoint = collection_map[role]
# Calls the helper function to process verification
75:             rec = _allowed_role_login(coll, email, password, role, id_key)
76:             
# Handles different return states from the verification helper
77:             if isinstance(rec, dict):
78:                 return redirect(url_for(endpoint)) # Success: Redirects to appropriate dashboard
79:             elif rec == "LOCKED":
80:                 flash("Account locked due to too many failed attempts. Try again in 15 minutes.", "danger")
81:                 return render_template("auth/login.html")
# ... Checks for PENDING_APPROVAL and BLOCKED similarly
89:         flash("Invalid email or password. Please try again.", "danger")
# Renders the login template on GET requests or on a totally invalid login attempt
90:     return render_template("auth/login.html")

# Defines user registration
93: # ─── Register User ────────────────────────────────────────────────────────────
94: @auth_bp.route("/register/user", methods=["GET", "POST"])
95: def register_user():
96:     if request.method == "POST":
# Captures user inputs
97:         name = request.form.get("name", "").strip()
